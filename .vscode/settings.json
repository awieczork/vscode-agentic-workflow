{
    // ═══════════════════════════════════════════════════════════════════════════
    // SECTION 1: ACCESSIBILITY
    // ═══════════════════════════════════════════════════════════════════════════

    "accessibility.signals.lineHasInlineSuggestion": { "sound": "off" },
    "accessibility.signals.terminalBell": { "sound": "off" },
    "accessibility.verbosity.panelChat": false,

    // ═══════════════════════════════════════════════════════════════════════════
    // SECTION 2: CHAT & AI (GitHub Copilot, MCP, Instructions)
    // ═══════════════════════════════════════════════════════════════════════════

    // Agent Mode
    "chat.agent.maxRequests": 200,
    "chat.checkpoints.enabled": true,
    "chat.customAgentInSubagent.enabled": true,
    "chat.editRequests": "input",
    "chat.edits2.enabled": true,
    "chat.editor.fontFamily": "Fira Code",
    "chat.editor.fontSize": 10,
    "chat.fontFamily": "Segoe UI",
    "chat.fontSize": 12,
    "chat.implicitContext.suggestedContext": false,
    "chat.instructionsFilesLocations": {
        ".github/instructions": true,
        ".github/instructions/**": true
    },
    "chat.promptFilesLocations": {
        ".github/prompts/**": true
    },
    "chat.renderRelatedFiles": true,
    "chat.restoreLastPanelSession": false,
    "chat.useAgentSkills": true,
    "chat.useAgentsMdFile": true,
    "chat.useNestedAgentsMdFiles": true,
    "chat.viewWelcome.enabled": false,

    // MCP (Model Context Protocol)
    "chat.mcp.access": "all",
    "chat.mcp.assisted.nuget.enabled": true,
    "chat.mcp.gallery.enabled": false,
    "chat.mcp.serverSampling": {
        "Global in Code: brave-search": {
            "allowedModels": ["copilot/claude-opus-4.5"]
        }
    },

    // Tool Auto-Approvals
    "chat.tools.eligibleForAutoApproval": {
        "fetch": true
    },
    "chat.tools.global.autoApprove": false,
    "chat.tools.terminal.autoApprove": {
        "/^Remove-Item\\b/i": false,
        "cat": true,
        "cd": true,
        "del": false,
        "dir": true,
        "echo": true,
        "ForEach-Object": true,
        "Get-ChildItem": true,
        "Get-Process": true,
        "Get-Service": true,
        "git branch": true,
        "git diff": true,
        "git log": true,
        "git status": true,
        "kill": false,
        "ls": true,
        "Measure-Object": true,
        "pwd": true,
        "rm": false,
        "rmdir": false,
        "Select-Object": true,
        "Sort-Object": true,
        "Test-Path": true,
        "type": true,
        "Where-Object": true
    },
    "chat.tools.terminal.autoReplyToPrompts": true,
    "chat.tools.terminal.blockDetectedFileWrites": "outsideWorkspace",
    "chat.tools.terminal.outputLocation": "terminal",
    "chat.tools.terminal.preventShellHistory": true,
    "chat.tools.terminal.terminalProfile.windows": null,
    "chat.tools.urls.autoApprove": {
        "https://*.anthropic.com": true,
        "https://*.claude.com": true,
        "https://*.cline.bot": true,
        "https://*.github.com": true,
        "https://*.github.io": true,
        "https://*.githubusercontent.com": true,
        "https://*.google.com": true,
        "https://*.microsoft.com": true,
        "https://*.modelcontextprotocol.io": true,
        "https://*.openai.com": true,
        "https://*.reddit.com": true,
        "https://*.visualstudio.com": true,
        "https://agentskills.io": true,
        "https://api.github.com": {
            "approveRequest": false,
            "approveResponse": true
        },
        "https://arxiv.org": true,
        "https://docs.python.org": {
            "approveRequest": false,
            "approveResponse": true
        },
        "https://github.blog": true,
        "https://kiro.dev": true,
        "https://stackoverflow.com": {
            "approveRequest": false,
            "approveResponse": true
        },
        "https://*.rtings.com": true
    },

    // GitHub Copilot Core
    "github.copilot.chat.agent.currentEditorContext.enabled": false,
    "github.copilot.chat.anthropic.thinking.budgetTokens": 16000,
    "github.copilot.chat.claudeCode.enabled": false,
    "github.copilot.chat.cli.customAgents.enabled": false,
    "github.copilot.chat.cli.mcp.enabled": true,
    "github.copilot.chat.codeGeneration.useInstructionFiles": true,
    "github.copilot.chat.codesearch.enabled": true,
    "github.copilot.chat.commitMessageGeneration.instructions": [
        { "text": "Use conventional commits: type(scope): description" },
        { "text": "Types: feat, fix, docs, refactor, test, chore, perf, ci" },
        { "text": "Summary under 50 chars, body under 72 chars per line" },
        { "text": "Use imperative mood (Add, Fix, Update, not Added)" }
    ],
    "github.copilot.chat.copilotDebugCommand.enabled": true,
    "github.copilot.chat.edits.suggestRelatedFilesFromGitHistory": false,
    "github.copilot.chat.generateTests.codeLens": true,
    "github.copilot.chat.githubMcpServer.enabled": true,
    "github.copilot.chat.localeOverride": "en",
    "github.copilot.chat.newWorkspaceCreation.enabled": true,
    "github.copilot.chat.notebook.enhancedNextEditSuggestions.enabled": true,
    "github.copilot.chat.notebook.followCellExecution.enabled": true,
    "github.copilot.chat.responsesApiReasoningEffort": "high",
    "github.copilot.chat.responsesApiReasoningSummary": "detailed",
    "github.copilot.chat.reviewSelection.enabled": true,
    "github.copilot.chat.reviewSelection.instructions": [
        { "text": "Check for security vulnerabilities (injection, XSS, SSRF)" },
        { "text": "Identify performance issues and algorithmic complexity" },
        { "text": "Verify proper error handling and edge cases" },
        { "text": "Suggest readability and maintainability improvements" }
    ],
    "github.copilot.chat.setupTests.enabled": true,
    "github.copilot.chat.summarizeAgentConversationHistory.enabled": true,
    "github.copilot.chat.useResponsesApi": true,
    "github.copilot.enable": {
        "*": true,
        "markdown": true,
        "plaintext": false
    },
    "github.copilot.nextEditSuggestions.enabled": true,

    // Inline Chat
    "inlineChat.enableV2": true,
    "inlineChat.finishOnType": true,
    "inlineChat.holdToSpeech": false,

    // ═══════════════════════════════════════════════════════════════════════════
    // SECTION 3: DEBUG
    // ═══════════════════════════════════════════════════════════════════════════

    "debug.console.closeOnEnd": true,
    "debug.console.fontFamily": "Fira Code",
    "debug.console.fontSize": 12,
    "debug.internalConsoleOptions": "openOnSessionStart",
    "debug.showBreakpointsInOverviewRuler": false,
    "debug.showDebugOutput": true,

    // ═══════════════════════════════════════════════════════════════════════════
    // SECTION 4: EDITOR (Appearance & Behavior)
    // ═══════════════════════════════════════════════════════════════════════════

    "editor.acceptSuggestionOnCommitCharacter": true,
    "editor.acceptSuggestionOnEnter": "on",
    "editor.accessibilitySupport": "off",
    "editor.bracketPairColorization.independentColorPoolPerBracketType": true,
    "editor.codeActionsOnSaveTimeout": 2000,
    "editor.codeLens": false,
    "editor.cursorBlinking": "phase",
    "editor.cursorSmoothCaretAnimation": "on",
    "editor.dragAndDrop": false,
    "editor.fontFamily": "Fira Code",
    "editor.fontLigatures": true,
    "editor.fontSize": 11,
    "editor.formatOnPaste": true,
    "editor.formatOnSave": false,
    "editor.glyphMargin": false,
    "editor.guides.bracketPairs": true,
    "editor.guides.indentation": false,
    "editor.hideCursorInOverviewRuler": true,
    "editor.hover.enabled": "off",
    "editor.inlineSuggest.edits.allowCodeShifting": "always",
    "editor.inlineSuggest.enabled": true,
    "editor.inlineSuggest.showToolbar": "onHover",
    "editor.largeFileOptimizations": true,
    "editor.lineHeight": 0,
    "editor.linkedEditing": true,
    "editor.matchBrackets": "never",
    "editor.minimap.enabled": false,
    "editor.mouseWheelZoom": true,
    "editor.occurrencesHighlight": "off",
    "editor.overviewRulerBorder": false,
    "editor.quickSuggestions": {
        "comments": "off",
        "other": "on",
        "strings": "off"
    },
    "editor.quickSuggestionsDelay": 0,
    "editor.renderLineHighlight": "none",
    "editor.renderWhitespace": "none",
    "editor.rulers": [88],
    "editor.scrollbar.horizontalScrollbarSize": 8,
    "editor.scrollbar.verticalScrollbarSize": 8,
    "editor.selectionHighlight": false,
    "editor.semanticTokenColorCustomizations": {
        "enabled": true,
        "rules": {
            "class": "#4ec9b0",
            "decorator": "#dcdcaa",
            "enum": "#4ec9b0",
            "enumMember": "#4fc1ff",
            "interface": "#4ec9b0",
            "parameter": "#9cdcfe",
            "property": "#9cdcfe"
        }
    },
    "editor.showUnused": true,
    "editor.smoothScrolling": true,
    "editor.stickyScroll.enabled": false,
    "editor.suggest.preview": true,
    "editor.suggest.showStatusBar": true,
    "editor.suggestSelection": "first",
    "editor.tabSize": 4,
    "editor.tokenColorCustomizations": {
        "comments": "#6a9955",
        "functions": "#dcdcaa",
        "keywords": "#569cd6",
        "numbers": "#b5cea8",
        "strings": "#ce9178",
        "textMateRules": [
            {
                "scope": ["comment", "comment.block", "comment.line"],
                "settings": { "fontStyle": "italic" }
            }
        ],
        "variables": "#9cdcfe"
    },
    "editor.wordWrap": "on",

    // ═══════════════════════════════════════════════════════════════════════════
    // SECTION 5: EXPLORER
    // ═══════════════════════════════════════════════════════════════════════════

    "explorer.compactFolders": false,
    "explorer.confirmDelete": false,
    "explorer.confirmDragAndDrop": false,
    "explorer.confirmPasteNative": false,
    "explorer.decorations.badges": false,
    "explorer.decorations.colors": false,
    "explorer.excludeGitIgnore": false,
    "explorer.fileNesting.enabled": true,
    "explorer.fileNesting.patterns": {
        "*.py": "${capture}.pyi, ${capture}_test.py, test_${capture}.py",
        ".gitignore": ".gitattributes, .gitmodules, .gitmessage, .mailmap",
        "pyproject.toml": "poetry.lock, setup.py, setup.cfg, requirements*.txt, .python-version, pyrightconfig.json"
    },
    "explorer.openEditors.visible": 1,
    "explorer.sortOrder": "type",

    // ═══════════════════════════════════════════════════════════════════════════
    // SECTION 6: EXTENSIONS
    // ═══════════════════════════════════════════════════════════════════════════

    "extensions.autoCheckUpdates": false,
    "extensions.autoUpdate": false,
    "extensions.experimental.affinity": {
        "github.copilot": 1,
        "github.copilot-chat": 2
    },
    "extensions.ignoreRecommendations": true,

    // ═══════════════════════════════════════════════════════════════════════════
    // SECTION 7: FILES
    // ═══════════════════════════════════════════════════════════════════════════

    "files.associations": {
        "*.agent.md": "markdown",
        "*.instructions.md": "markdown",
        "*.prompt.md": "markdown",
        "*-instructions.md": "markdown",
        "copilot-instructions.md": "markdown"
    },
    "files.autoSave": "onFocusChange",
    "files.autoSaveDelay": 2000,
    "files.autoSaveWhenNoErrors": true,
    "files.eol": "\n",
    "files.exclude": {
        "**/*.min.js": true,
        "**/.git": true,
        "**/.venv": true,
        "**/__pycache__": true,
        "**/build": true,
        "**/coverage": true,
        "**/dist": true,
        "**/node_modules": true,
        "**/vendor": true
    },
    "files.insertFinalNewline": true,
    "files.participants.timeout": 60000,
    "files.trimFinalNewlines": true,
    "files.trimTrailingWhitespace": true,
    "files.watcherExclude": {
        "**/*.egg-info/**": true,
        "**/.cache/**": true,
        "**/.git/objects/**": true,
        "**/.git/subtree-cache/**": true,
        "**/.mypy_cache/**": true,
        "**/.next/**": true,
        "**/.pytest_cache/**": true,
        "**/.ruff_cache/**": true,
        "**/.venv/**": true,
        "**/__pycache__/**": true,
        "**/build/**": true,
        "**/coverage/**": true,
        "**/dist/**": true,
        "**/logs/**": true,
        "**/node_modules/**": true,
        "**/tmp/**": true
    },

    // ═══════════════════════════════════════════════════════════════════════════
    // SECTION 8: GIT
    // ═══════════════════════════════════════════════════════════════════════════

    "git.autofetch": true,
    "git.autofetchPeriod": 300,
    "git.blame.statusBarItem.enabled": false,
    "git.confirmSync": false,
    "git.enableSmartCommit": true,
    "git.ignoreLimitWarning": true,
    "git.mergeEditor": true,
    "git.openRepositoryInParentFolders": "always",
    "git.showProgress": true,

    // ═══════════════════════════════════════════════════════════════════════════
    // SECTION 9: HTTP & NETWORK
    // ═══════════════════════════════════════════════════════════════════════════

    "http.proxySupport": "override",

    // ═══════════════════════════════════════════════════════════════════════════
    // SECTION 10: LANGUAGE-SPECIFIC OVERRIDES
    // ═══════════════════════════════════════════════════════════════════════════

    "[chatagent]": {
        "diffEditor.ignoreTrimWhitespace": true
    },

    "[dockerfile]": {
        "editor.tabSize": 4
    },

    "[json]": {
        "editor.defaultFormatter": "vscode.json-language-features",
        "editor.tabSize": 2
    },

    "[jsonc]": {
        "editor.defaultFormatter": "vscode.json-language-features",
        "editor.tabSize": 2
    },

    "[markdown]": {
        "editor.codeActionsOnSave": {},
        "editor.formatOnSave": false,
        "editor.quickSuggestions": {
            "comments": "off",
            "other": "off",
            "strings": "off"
        },
        "editor.tabSize": 2,
        "editor.wordWrap": "on",
        "files.trimTrailingWhitespace": false
    },

    "[powershell]": {
        "editor.formatOnSave": false,
        "editor.tabSize": 4
    },

    "[python]": {
        "editor.formatOnSave": true
    },

    "[shellscript]": {
        "editor.tabSize": 4
    },

    "[toml]": {
        "editor.tabSize": 2
    },

    "[yaml]": {
        "editor.autoIndent": "advanced",
        "editor.tabSize": 2
    },

    // ═══════════════════════════════════════════════════════════════════════════
    // SECTION 11: NPM & TYPESCRIPT
    // ═══════════════════════════════════════════════════════════════════════════

    "npm.autoDetect": "off",
    "typescript.disableAutomaticTypeAcquisition": true,

    // ═══════════════════════════════════════════════════════════════════════════
    // SECTION 12: PYTHON
    // ═══════════════════════════════════════════════════════════════════════════

    "python.analysis.aiHoverSummaries": true,
    "python.analysis.autoImportCompletions": true,
    "python.analysis.cachingLevel": "system",
    "python.analysis.completeFunctionParens": true,
    "python.analysis.diagnosticMode": "openFilesOnly",
    "python.analysis.indexing": true,
    "python.analysis.inlayHints.functionReturnTypes": false,
    "python.analysis.inlayHints.variableTypes": false,
    "python.analysis.typeCheckingMode": "basic",
    "python.analysis.useLibraryCodeForTypes": true,
    "python.terminal.activateEnvironment": false,
    "python.terminal.activateEnvInCurrentTerminal": false,
    "python.testing.autoTestDiscoverOnSaveEnabled": false,
    "python.testing.pytestEnabled": true,
    "python.testing.unittestEnabled": false,

    // ═══════════════════════════════════════════════════════════════════════════
    // SECTION 13: SEARCH
    // ═══════════════════════════════════════════════════════════════════════════

    "search.collapseResults": "auto",
    "search.exclude": {
        "**/*.egg-info": true,
        "**/.mypy_cache": true,
        "**/.pytest_cache": true,
        "**/.ruff_cache": true,
        "**/.venv": true,
        "**/__pycache__": true,
        "**/build": true,
        "**/dist": true,
        "**/mlruns": true,
        "**/node_modules": true,
        "**/venv": true,
        "**/wandb": true
    },
    "search.followSymlinks": false,
    "search.maxResults": 10000,
    "search.searchOnType": false,
    "search.smartCase": true,

    // ═══════════════════════════════════════════════════════════════════════════
    // SECTION 14: SECURITY
    // ═══════════════════════════════════════════════════════════════════════════

    "security.workspace.trust.enabled": false,
    "security.workspace.trust.untrustedFiles": "open",

    // ═══════════════════════════════════════════════════════════════════════════
    // SECTION 15: TELEMETRY & UPDATES
    // ═══════════════════════════════════════════════════════════════════════════

    "telemetry.telemetryLevel": "off",
    "update.mode": "start",
    "update.showReleaseNotes": true,

    // ═══════════════════════════════════════════════════════════════════════════
    // SECTION 16: TERMINAL
    // ═══════════════════════════════════════════════════════════════════════════

    "terminal.external.windowsExec": "pwsh.exe",
    "terminal.integrated.copyOnSelection": true,
    "terminal.integrated.cursorStyle": "line",
    "terminal.integrated.cwd": "${workspaceFolder}",
    "terminal.integrated.defaultProfile.windows": "PowerShell",
    "terminal.integrated.env.windows": {
        "PYTHONUNBUFFERED": "1"
    },
    "terminal.integrated.fontFamily": "Consolas",
    "terminal.integrated.fontSize": 11,
    "terminal.integrated.gpuAcceleration": "on",
    "terminal.integrated.hideOnStartup": "always",
    "terminal.integrated.inheritEnv": true,
    "terminal.integrated.persistentSessionReviveProcess": "never",
    "terminal.integrated.profiles.windows": {
        "Command Prompt": {
            "args": [],
            "icon": "terminal-cmd",
            "path": ["${env:windir}\\Sysnative\\cmd.exe", "${env:windir}\\System32\\cmd.exe"]
        },
        "Git Bash": {
            "icon": "terminal-git-bash",
            "source": "Git Bash"
        },
        "PowerShell": {
            "args": ["-NoLogo"],
            "icon": "terminal-powershell",
            "source": "PowerShell"
        }
    },
    "terminal.integrated.reconnectDelay": 100,
    "terminal.integrated.scrollback": 10000,
    "terminal.integrated.shellIntegration.enabled": true,
    "terminal.integrated.smoothScrolling": true,
    "terminal.integrated.stickyScroll.enabled": false,
    "terminal.integrated.tabs.defaultColor": "terminal.ansiGreen",
    "terminal.integrated.tabs.defaultIcon": "terminal-powershell",
    "terminal.integrated.tabs.enabled": true,
    "terminal.integrated.tabs.location": "right",

    // ═══════════════════════════════════════════════════════════════════════════
    // SECTION 17: WINDOW
    // ═══════════════════════════════════════════════════════════════════════════

    "window.commandCenter": false,
    "window.customTitleBarVisibility": "auto",
    "window.enableMenuBarMnemonics": true,
    "window.enableWindowsJumpList": false,
    "window.menuBarVisibility": "compact",
    "window.newWindowDimensions": "inherit",
    "window.restoreWindows": "none",
    "window.title": "${rootName}${separator}${activeEditorShort}${separator}${activeEditorLanguageId}",
    "window.titleBarStyle": "custom",

    // ═══════════════════════════════════════════════════════════════════════════
    // SECTION 18: WORKBENCH (Theme, Layout, Behavior)
    // ═══════════════════════════════════════════════════════════════════════════

    "breadcrumbs.enabled": true,
    "workbench.activityBar.location": "top",
    "workbench.colorCustomizations": {
        "activityBar.activeBackground": "#373e47",
        "activityBar.border": "#00000000",
        "activityBarBadge.background": "#539bf5",
        "breadcrumb.background": "#00000000",
        "contrastBorder": "#00000000",
        "editor.lineHighlightBackground": "#393e42",
        "editor.selectionBackground": "#264f78",
        "editor.selectionHighlightBackground": "#add6ff26",
        "editorGroup.border": "#00000000",
        "editorGroupHeader.border": "#00000000",
        "editorGroupHeader.tabsBorder": "#00000000",
        "editorLineNumber.activeForeground": "#6a9955",
        "editorSuggestWidget.highlightForeground": "#539bf5",
        "editorWidget.background": "#2d333b",
        "panel.border": "#00000000",
        "scrollbar.shadow": "#00000000",
        "scrollbarSlider.background": "#545d6850",
        "scrollbarSlider.hoverBackground": "#656d7680",
        "sideBar.border": "#00000000",
        "statusBar.background": "#22272e",
        "statusBar.border": "#00000000",
        "statusBar.debuggingBackground": "#347d39",
        "statusBar.foreground": "#768390",
        "tab.activeBorder": "#00000000",
        "tab.activeBorderTop": "#00000000",
        "tab.border": "#00000000",
        "tab.unfocusedActiveBorder": "#00000000",
        "tab.unfocusedActiveBorderTop": "#00000000",
        "terminal.background": "#1c2024",
        "terminal.foreground": "#adbac7",
        "titleBar.border": "#00000000",
        "widget.border": "#00000000"
    },
    "workbench.colorTheme": "GitHub Dark Dimmed",
    "workbench.commandPalette.experimental.suggestCommands": true,
    "workbench.commandPalette.history": 10,
    "workbench.editor.centeredLayoutFixedWidth": true,
    "workbench.editor.enablePreview": true,
    "workbench.editor.enablePreviewFromCodeNavigation": false,
    "workbench.editor.highlightModifiedTabs": true,
    "workbench.editor.limit.enabled": true,
    "workbench.editor.limit.perEditorGroup": true,
    "workbench.editor.limit.value": 8,
    "workbench.editor.restoreViewState": false,
    "workbench.editor.tabSizing": "shrink",
    "workbench.editor.wrapTabs": true,
    "workbench.enableExperiments": false,
    "workbench.iconTheme": "vscode-icons",
    "workbench.layoutControl.enabled": true,
    "workbench.list.smoothScrolling": true,
    "workbench.reduceMotion": "on",
    "workbench.sideBar.location": "right",
    "workbench.tips.enabled": false,
    "workbench.tree.indent": 16,
    "workbench.tree.renderIndentGuides": "always",

    // ═══════════════════════════════════════════════════════════════════════════
    // SECTION 19: ZEN MODE
    // ═══════════════════════════════════════════════════════════════════════════

    "zenMode.centerLayout": true,
    "zenMode.fullScreen": false,
    "zenMode.hideActivityBar": true,
    "zenMode.hideLineNumbers": false,
    "zenMode.hideStatusBar": true,
    "zenMode.showTabs": "single",
    "zenMode.silentNotifications": true,

    // ═══════════════════════════════════════════════════════════════════════════
    // SECTION 20: EXTENSIONS: POWERSHELL
    // ═══════════════════════════════════════════════════════════════════════════

    "powershell.codeFormatting.Preset": "OTBS",
    "powershell.debugging.createTemporaryIntegratedConsole": true,
    "powershell.scriptAnalysis.enable": true,
    "powershell.startAsLoginProfile": false,
    "powershell.startAutomatically": false,

    // ═══════════════════════════════════════════════════════════════════════════
    // SECTION 21: EXTENSIONS: VSCODE ICONS
    // ═══════════════════════════════════════════════════════════════════════════

    "vsicons.dontShowNewVersionMessage": true
}
